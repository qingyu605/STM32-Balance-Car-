    while (1) {
        if(HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_8) == GPIO_PIN_RESET) {
						HAL_Delay(30); 
					if(HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_8) == GPIO_PIN_RESET) {
            HAL_GPIO_TogglePin(LED_GPIO_Port, LED_Pin); /* LED引脚电平翻转 */
            //HAL_Delay(2000);                            /* 延时500ms */
        }
			}
    }
